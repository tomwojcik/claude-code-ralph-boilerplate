FROM debian:bookworm-slim AS base

RUN apt-get update && apt-get install -y \
    curl \
    git \
    build-essential \
    make \
    ca-certificates \
    gnupg \
    wget \
    bubblewrap \
    unzip \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get update \
    && apt-get install -y nodejs \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --break-system-packages polars

WORKDIR /workspace

FROM base AS codex

RUN npm i -g @openai/codex \
    && useradd -m -s /bin/bash -u 1000 codex \
    && mkdir -p /home/codex/.codex \
    && chown -R 1000:1000 /home/codex/.codex

USER codex

ENTRYPOINT ["/usr/bin/codex"]

FROM base AS claude

RUN npm i -g @anthropic-ai/claude-code \
    && useradd -m -s /bin/bash -u 1000 claude

USER claude

ENTRYPOINT ["/usr/bin/claude", "--dangerously-skip-permissions"]
